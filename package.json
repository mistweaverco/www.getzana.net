		"svelte-check": "4.4.8",
		"svelte-sitemap": "3.1.0",
		"tailwindcss": "4.3.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.59.3",
		"vite": "catalog:",
		"vitest": "catalog:",
		"yaml": "2.9.0",
		"vite-plus": "catalog:"
	},
	"packageManager": "pnpm@11.1.1"
