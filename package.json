		"@sveltejs/kit": "2.59.1",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.3.0",
		"@types/eslint": "9.6.1",
		"@types/node": "25.7.0",
		"daisyui": "5.5.19",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"glob": "13.0.6",
		"globals": "17.6.0",
		"install": "0.13.0",
		"jiti": "2.7.0",
		"mdsvex": "0.12.7",
