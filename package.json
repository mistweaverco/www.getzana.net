		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && vp lint ."
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@fortawesome/fontawesome-free": "7.2.0",
